        <field 
            name="search" 
            type="text" 
            description="Part Number / Model Number / Product Description"
            label="COM_USERS_FILTER_SEARCH_DESC"
            class="js-stools-search-string"
            hint="Part Number / Model Number / Product Description" />
    </fields>

    <fields name="list">
       <field name="limit"
               type="limitbox"
               label="COM_ATELMAN_LIST_LIMIT"
               description="COM_ATELMAN_LIST_LIMIT_DESC"
