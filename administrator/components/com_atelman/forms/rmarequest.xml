<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Atelman\Component\Atelman\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="user_id" type="user" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_USER_ID" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_USER_ID" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_USER_ID"/>
    <field name="fullname" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_FULLNAME" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_FULLNAME" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_FULLNAME"/>
    <field name="contact_name" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_CONTACT_NAME" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_CONTACT_NAME" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_CONTACT_NAME"/>
    <field name="address" type="textarea" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_ADDRESS" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_ADDRESS" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_ADDRESS"/>
    <field name="city" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_CITY" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_CITY" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_CITY"/>
    <field name="state" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1" default="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="postal_code" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_POSTAL_CODE" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_POSTAL_CODE" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_POSTAL_CODE"/>
    <field name="country" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_COUNTRY" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_COUNTRY" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_COUNTRY"/>
    <field name="telephone" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_TELEPHONE" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_TELEPHONE" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_TELEPHONE"/>
    <field name="fax" type="text" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_FAX" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_FAX" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_FAX"/>
    <field name="email" validate="email" type="email" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_EMAIL" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_EMAIL" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_EMAIL"/>
    <field name="created_date" default="CURRENT_TIMESTAMP" class="inputbox" format="%Y-%m-%d" translateformat="false" showtime="false" singleheader="false" todaybutton="false" weeknumbers="false" filltable="false" type="calendar" label="COM_ATELMAN_FORM_LBL_RMAREQUEST_CREATED_DATE" description="COM_ATELMAN_FORM_DESC_RMAREQUEST_CREATED_DATE" hint="COM_ATELMAN_FORM_LBL_RMAREQUEST_CREATED_DATE"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
</form>
